# ── Firebase (waitlist storage) ──
# The app ships with working defaults baked in (see lib/firebase.ts).
# Override here only if you point it at a different Firebase project.
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""

# ── Email (Resend) ──
# https://resend.com — free 3,000/mo. Verify vixo.live to send as your domain.
RESEND_API_KEY=""
EMAIL_FROM="NicheSpy <support@vixo.live>"

# ── Google Analytics 4 ──
# GA4 → Admin → Data Streams → Web → Measurement ID (G-XXXXXXX)
NEXT_PUBLIC_GA_ID=""

# ── Cloudflare Turnstile (bot protection on the waitlist form) ──
# Free keys: https://dash.cloudflare.com → Turnstile → Add site.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""   # public, used in the browser widget
TURNSTILE_SECRET_KEY=""             # secret, used server-side to verify

# ── Discord bot notifications (nichespy-bot project) ──
BOT_NOTIFY_URL=""        # bot public URL, e.g. https://nichespy-bot.up.railway.app
BOT_NOTIFY_SECRET=""     # must match NOTIFY_SECRET in the bot

# ── Site ──
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
